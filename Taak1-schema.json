{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Taak1_Leidingen",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta_groep_id",
    "leidingen"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "optionele referentie naar schema locatie"
    },
    "meta_groep_id": {
      "type": "string",
      "pattern": "^gr(?!000$)\\d{3}$",
      "description": "groepscode, bijv. gr012 (gr000 is niet toegestaan)"
    },
    "meta_databron": {
      "type": "string",      
      "description": "beschrijving herkomst en voorzien gebruik van dataset, bijv. auteurnaam, scriptnaam, generatornaam..."
    },
    "meta_timestamp": {
      "type": "string",
      "pattern": "^[0-9]{8}-[0-9]{6}$",
      "description": "time stamp in yyyymmdd-hhmmss voor versie-identificatie"
    },
    "meta_opm": {
      "type": "string",      
      "description": "opmerkingen"
    },
    "leidingen": {
      "type": "array",
      "description": "array met elementen (key-value pairs) die elke leiding beschrijven",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "descr",
          "L",
          "DN",
          "Tw",
          "Q_d",
          "c_d",
          "h_grad_d",          
          "h_w_d",
          "L_eq",
          "C_w"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!([Tt][Bb][Dd])$).*\\S.*$",
            "description": "identificatie van leiding; mag niet leeg, niet enkel spaties en niet 'TBD' zijn"
          },
          "descr": {
            "type": "string",
            "description": "beschrijving van item (optioneel)"
          },
          "L": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "eenheid [m], fysieke lengte van leiding"
          },          
          "DN": {
            "type": "string",
            "enum": [
              "DN15",
              "DN20",
              "DN25",
              "DN32",
              "DN40",
              "DN50",
              "DN65",
              "DN80",
              "DN100",
              "DN125",
              "DN150",
              "DN200",
              "DN250",
              "DN300",
              "DN350",
              "DN400",
              "DN450",
              "DN500"
            ],
            "description": "nominale leidingdiameter code inclusief DN, bijv. DN80"
          },
          "Tw": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "eenheid [mm], wanddikte van leiding"
          },
          "Q_d": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "eenheid [m3/h]; ontwerpdebiet van leiding"
          },
          "c_d": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "eenheid [m/s]; snelheid bij ontwerpdebiet"
          },
          "h_grad_d": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "eenheid [m/m]; hydraulische gradient door leidingsverlies bij ontwerpdebiet, verlies van een meter buislengte"
          },
          "h_w_d": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "eenheid [m]; wrijvingsverlies bij ontwerpdebiet"
          },
          "L_eq": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "eenheid [m]; equivalente lengte van leiding"
          },
          "C_w": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "eenheid [m]; wrijvingsverliescoefficient zodat h_w = C_w * (Q*(h/m3))^2"
          }
        }
      }
    }
  }
}
